 MIT
diff -ru old/tests/test_utils.py new/tests/test_utils.py
--- old/tests/test_utils.py	2024-01-10 09:12:33.000000000 +0000
+++ new/tests/test_utils.py	2024-01-12 14:05:07.000000000 +0000
@@ -1,11 +1,14 @@
-from src.utils import now_ms, clamp
+from src.utils import now_ms, clamp, is_blank


 def test_now_ms_is_positive():
     assert now_ms() > 0


 def test_clamp_bounds():
     assert clamp(5, 0, 10) == 5
     assert clamp(-1, 0, 10) == 0
     assert clamp(20, 0, 10) == 10
+
+
+def test_is_blank():
+    assert is_blank("   ")
+    assert not is_blank("x")
