commit 9f3c1a7b2e84d05612af0c9d7e3b4a18c2d6e0f1 (HEAD -> main, origin/main)
Author: Pat Developer <pat@example.com>
Date:   Tue Mar 12 09:41:23 2024 +0000

    feat(auth): add token refresh and session expiry handling

    Sessions previously stayed valid until the process restarted, which
    let stale tokens linger far past their intended lifetime. This change
    introduces an explicit refresh path and a background sweep that drops
    expired sessions.

    - refresh tokens within the grace window before expiry
    - drop sessions once past hard expiry
    - cover the new paths with unit tests

diff --git a/src/auth/session.rs b/src/auth/session.rs
index 1a2b3c4..5d6e7f8 100644
--- a/src/auth/session.rs
+++ b/src/auth/session.rs
@@ -1,12 +1,18 @@
 use std::collections::HashMap;
+use std::time::{Duration, Instant};

 pub struct Session {
     pub id: String,
     pub token: String,
+    pub issued_at: Instant,
+    pub expires_at: Instant,
 }

 pub struct SessionStore {
     sessions: HashMap<String, Session>,
+    grace: Duration,
 }

 impl SessionStore {
@@ -20,15 +26,38 @@ impl SessionStore {
     pub fn new() -> Self {
         Self {
             sessions: HashMap::new(),
+            grace: Duration::from_secs(60),
         }
     }

-    pub fn get(&self, id: &str) -> Option<&Session> {
-        self.sessions.get(id)
+    pub fn get(&mut self, id: &str) -> Option<&Session> {
+        let now = Instant::now();
+        if let Some(s) = self.sessions.get(id) {
+            if s.expires_at <= now {
+                self.sessions.remove(id);
+                return None;
+            }
+        }
+        self.sessions.get(id)
     }

-    pub fn insert(&mut self, s: Session) {
-        self.sessions.insert(s.id.clone(), s);
+    pub fn insert(&mut self, s: Session) {
+        self.sessions.insert(s.id.clone(), s);
+    }
+
+    pub fn refresh(&mut self, id: &str) -> bool {
+        let now = Instant::now();
+        if let Some(s) = self.sessions.get_mut(id) {
+            if s.expires_at.saturating_duration_since(now) <= self.grace {
+                s.issued_at = now;
+                s.expires_at = now + Duration::from_secs(3600);
+                return true;
+            }
+        }
+        false
+    }
+
+    pub fn sweep_expired(&mut self) {
+        let now = Instant::now();
+        self.sessions.retain(|_, s| s.expires_at > now);
     }
 }
