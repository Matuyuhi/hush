diff --git a/src/auth/refresh.rs b/src/auth/refresh.rs
new file mode 100644
index 0000000..c0ffee0
--- /dev/null
+++ b/src/auth/refresh.rs
@@ -0,0 +1,24 @@
+use crate::auth::SessionStore;
+
+pub struct Refresher {
+    interval_secs: u64,
+}
+
+impl Refresher {
+    pub fn new(interval_secs: u64) -> Self {
+        Self { interval_secs }
+    }
+
+    pub fn tick(&self, store: &mut SessionStore) {
+        store.sweep_expired();
+    }
+
+    pub fn interval(&self) -> u64 {
+        self.interval_secs
+    }
+}
+
+impl Default for Refresher {
+    fn default() -> Self {
+        Self::new(30)
+    }
+}
diff --git a/tests/session_test.rs b/tests/session_test.rs
index 1111111..2222222 100644
--- a/tests/session_test.rs
+++ b/tests/session_test.rs
@@ -10,6 +10,28 @@ fn insert_and_get() {
     store.insert(make_session("a"));
     assert!(store.get("a").is_some());
 }
+
+#[test]
+fn expired_session_is_dropped() {
+    let mut store = SessionStore::new();
+    store.insert(make_expired_session("b"));
+    assert!(store.get("b").is_none());
+}
+
+#[test]
+fn refresh_extends_expiry() {
+    let mut store = SessionStore::new();
+    store.insert(make_near_expiry_session("c"));
+    assert!(store.refresh("c"));
+    assert!(store.get("c").is_some());
+}
+
+#[test]
+fn sweep_removes_only_expired() {
+    let mut store = SessionStore::new();
+    store.insert(make_session("live"));
+    store.insert(make_expired_session("dead"));
+    store.sweep_expired();
+    assert!(store.get("live").is_some());
+    assert!(store.get("dead").is_none());
+}
